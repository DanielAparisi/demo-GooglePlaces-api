# Copia este archivo como .env en la raíz del proyecto y rellena los valores.
# El .env real está en .gitignore y nunca debe subirse a git.

# Gmail (App Password de 16 caracteres: myaccount.google.com → Seguridad → Contraseñas de aplicación)
GMAIL_USER=tu_email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Groq (console.groq.com → API Keys)
GROQ_API_KEY=gsk_...

# Google Places (console.cloud.google.com → Credenciales)
GOOGLE_PLACES_API_KEY=AIza...

# scrape.do
SCRAPEDO_TOKEN=...

# Instagram (opcional, para send_instagram.py)
IG_USER=
IG_PASS=
